# Kinalys web (CRA) environment config — copy to .env and adjust per environment.
# Only REACT_APP_* vars reach the browser bundle. These are non-secret SPA
# values (the Auth0 clientId is public by design); the Anthropic key is
# backend-only and never belongs here.

# API base URL. client.ts falls back to http://localhost:3000 if unset.
REACT_APP_API_URL=http://localhost:3000

# Auth0 SPA config. REQUIRED — no fallback in code: if any is missing the app
# fails fast at startup rather than silently using a wrong tenant.
REACT_APP_AUTH0_DOMAIN=dev-zb6uoyfyk6iqoje2.us.auth0.com
REACT_APP_AUTH0_CLIENT_ID=fEN2zDxKe33gZWfF056qdlxEtDy9iYi1
REACT_APP_AUTH0_AUDIENCE=https://api.kinalys.io
